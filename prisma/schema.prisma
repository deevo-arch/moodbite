generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   // "ADMIN", "RESTAURANT", "DELIVERY", "USER"
  status    String   @default("VERIFIED") // VERIFIED, PENDING

  // Relations
  orders       Order[] @relation("UserOrders")
  menuItems    MenuItem[] @relation("RestaurantMenu")
  bakingOrders Order[] @relation("RestaurantOrders")
  deliveries   Order[] @relation("DeliveryOrders")
  
  // Specific fields
  address      String?
  rating       Float?
  avatarUrl    String?
}

model MenuItem {
  id           String @id @default(uuid())
  name         String
  description  String
  price        Float
  tags         String // CSV e.g., "Happy,Comfort"
  imageUrl     String?

  restaurantId String
  restaurant   User   @relation("RestaurantMenu", fields: [restaurantId], references: [id], onDelete: Cascade)
  orderItems   OrderItem[]
}

model Order {
  id           String @id @default(uuid())
  status       String @default("PENDING") // PENDING, PREPARING, READY, ARRIVED, PICKED_UP, DELIVERED
  total        Float

  userId       String
  user         User   @relation("UserOrders", fields: [userId], references: [id])

  restaurantId String
  restaurant   User   @relation("RestaurantOrders", fields: [restaurantId], references: [id])

  deliveryId   String?
  delivery     User?  @relation("DeliveryOrders", fields: [deliveryId], references: [id])

  items        OrderItem[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model OrderItem {
  id         String @id @default(uuid())
  orderId    String
  order      Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
}
